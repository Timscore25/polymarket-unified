# Polymarket Unified Trading System Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API ENDPOINTS
# =============================================================================
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_API_URL=https://gamma-api.polymarket.com

# =============================================================================
# AUTHENTICATION (Required for live trading)
# =============================================================================
# Your Polygon wallet private key (without 0x prefix)
PRIVATE_KEY=

# Your wallet's public address
PUBLIC_ADDRESS=

# =============================================================================
# TRADING MODE
# =============================================================================
# Set to true to simulate trades without executing (RECOMMENDED for testing)
DRY_RUN=true

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# MARKET CONFIGURATION
# =============================================================================
# Asset to trade: btc, eth, sol, xrp
MARKET_TYPE=btc

# Timeframes to trade (comma-separated): 5m, 15m, 1h
TIMEFRAMES=5m,15m

# =============================================================================
# MARKET MAKING SETTINGS
# =============================================================================
# Enable market making strategy
MM_ENABLED=true

# Minimum spread in basis points (10 = 0.1%)
MM_SPREAD_BPS=10

# Default order size in USD
MM_DEFAULT_SIZE=100

# Quote refresh rate in milliseconds
MM_REFRESH_MS=500

# Order lifetime before cancellation in milliseconds
MM_ORDER_LIFETIME_MS=3000

# =============================================================================
# ARBITRAGE SETTINGS
# =============================================================================
# Enable cross-market arbitrage
ARB_ENABLED=true

# Sum of asks threshold to trigger arbitrage (< 1.0 means profit opportunity)
ARB_THRESHOLD=0.99

# Order size for arbitrage in shares
ARB_SIZE=50

# Seconds to wait before verifying fill status
ARB_VERIFY_FILL_SECS=10

# =============================================================================
# RISK MANAGEMENT
# =============================================================================
# Maximum long exposure in USD
MAX_EXPOSURE_USD=10000

# Maximum short exposure in USD (negative value)
MIN_EXPOSURE_USD=-10000

# Maximum single order size in USD
MAX_POSITION_SIZE_USD=5000

# Maximum inventory skew (0.3 = 30%)
MAX_SKEW=0.3

# =============================================================================
# PERFORMANCE
# =============================================================================
# Main loop tick interval in milliseconds
TICK_INTERVAL_MS=100

# Enable batch order cancellations
BATCH_CANCELLATIONS=true

# =============================================================================
# MONITORING
# =============================================================================
# Enable Prometheus metrics endpoint
METRICS_ENABLED=true

# Metrics server port
METRICS_PORT=9306
